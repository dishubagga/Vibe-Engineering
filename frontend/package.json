{
  "name": "fullstack-frontend",
  "version": "1.0.0",
  "description": "React 18.2.0 + Vite + Redux Toolkit",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@reduxjs/toolkit": "1.9.7",
    "axios": "^1.7.9",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-redux": "8.1.3",
    "react-router-dom": "^6.30.3",
    "zustand": "4.4.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.1.5",
    "@testing-library/react": "14.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "8.56.0",
    "eslint-plugin-react": "7.34.0",
    "prettier": "3.2.5",
    "typescript": "5.6.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  }
}
